<Window x:Class="whisperMeOff.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="whisperMeOff"
        Height="800" Width="800"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}"
        PreviewKeyDown="Window_PreviewKeyDown">
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="56" ResizeBorderThickness="5" CornerRadius="8" GlassFrameThickness="0" UseAeroCaptionButtons="False"/>
    </WindowChrome.WindowChrome>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="20,15"
                WindowChrome.IsHitTestVisibleInChrome="True"
                MouseLeftButtonDown="Header_MouseLeftButtonDown">
            <Grid WindowChrome.IsHitTestVisibleInChrome="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status Indicator -->
                    <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}" x:Name="StatusIndicator"/>
                    <TextBlock Text="Ready" FontSize="16" FontWeight="SemiBold" Margin="10,0,0,0"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Ctrl+Shift+" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="R" x:Name="HotkeyDisplay" Foreground="{DynamicResource AccentBrush}"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="Settings" Click="OpenSettings_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"/>
                </StackPanel>

                <!-- Window Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Content="&#xE949;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MinimizeButton_Click" 
                            Background="Transparent" BorderThickness="0" Padding="10,8"
                            Foreground="{DynamicResource TextBrush}" ToolTip="Minimize"/>
                    <Button Content="&#xE739;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="MaximizeButton_Click" 
                            Background="Transparent" BorderThickness="0" Padding="10,8"
                            Foreground="{DynamicResource TextBrush}" ToolTip="Maximize"/>
                    <Button Content="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"
                            WindowChrome.IsHitTestVisibleInChrome="True"
                            Click="CloseButton_Click" 
                            Background="Transparent" BorderThickness="0" Padding="10,8"
                            Foreground="{DynamicResource TextBrush}" ToolTip="Close"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
            <TabControl.Resources>
                <!-- Tab Item Style with Fade Animation -->
                <Style TargetType="TabItem">
                    <Setter Property="Opacity" Value="0.6"/>
                    <Setter Property="Padding" Value="12,8"/>
                    <Setter Property="FontSize" Value="14"/>
                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="TabItem">
                                <Border x:Name="Border" Padding="{TemplateBinding Padding}" CornerRadius="4" Margin="2">
                                    <ContentPresenter x:Name="ContentSite" ContentSource="Header" HorizontalAlignment="Center"/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Opacity" Value="1"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource CardBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Opacity" Value="0.8"/>
                                    </Trigger>
                                    <MultiTrigger>
                                        <MultiTrigger.Conditions>
                                            <Condition Property="IsSelected" Value="True"/>
                                        </MultiTrigger.Conditions>
                                        <MultiTrigger.EnterActions>
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                   From="0.6" To="1" Duration="0:0:0.2"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </MultiTrigger.EnterActions>
                                    </MultiTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </TabControl.Resources>
            <!-- Home Tab -->
            <TabItem Header="Home">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Welcome Section -->
                        <TextBlock Text="whisperMeOff" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Offline voice-to-text transcription with auto-paste"
                                   FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,20"/>

                        <!-- Quick Start -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Quick Start" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock x:Name="QuickStartInstruction1" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,0,0"/>
                                <TextBlock x:Name="QuickStartInstruction2" Text="2. Speak your text" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                                <TextBlock x:Name="QuickStartInstruction3" TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Last Transcription -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Last Transcription" FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <Button x:Name="CopyLastTranscriptionBtn" Grid.Column="1" Content="📋 Copy"
                                            Click="CopyLastTranscription_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}" 
                                            Padding="10,4" FontSize="12"/>
                                </Grid>
                                <TextBlock x:Name="LastTranscriptionText" Text="No transcriptions yet"
                                           TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,10,0,0" MaxHeight="100"/>
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                    <TextBlock x:Name="LastTranscriptionStats" Text=""
                                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Recording Button (Fallback) -->
                        <Button Content="Start Recording" x:Name="RecordButton" Click="RecordButton_Click"
                                Style="{DynamicResource PrimaryButtonStyle}" Margin="0,20,0,0"
                                HorizontalAlignment="Left" Padding="30,10"
                                AutomationProperties.Name="Start Recording button"/>

                        <!-- Audio Level Meter -->
                        <ProgressBar x:Name="AudioLevelMeter" Height="8" Margin="0,10,0,0"
                                     Minimum="0" Maximum="1" Value="0"
                                     Visibility="Collapsed"
                                     Background="{DynamicResource CardBrush}"
                                     Foreground="{DynamicResource AccentBrush}"/>

                        <!-- Today's Session Stats -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15,10" Margin="0,15,0,0"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                            <Button x:Name="SessionStatsButton" Click="SessionStatsButton_Click" 
                                    Background="Transparent" BorderThickness="0"
                                    Padding="0" Margin="0"
                                    Cursor="Hand" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock x:Name="SessionStatsText" Text="Today: 0 transcriptions · 0 words"
                                               Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold"/>
                                </StackPanel>
                            </Button>
                        </Border>

                        <!-- Model Status - Dashboard -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Status" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Whisper Status - Clickable -->
                                    <TextBlock Text="Whisper:" Grid.Row="0" Grid.Column="0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                                        <TextBlock x:Name="WhisperStatusText" Text="Not loaded" 
                                                   Foreground="{DynamicResource TextBrush}" Cursor="Hand"
                                                   MouseLeftButtonDown="WhisperStatus_Click"
                                                   ToolTipService.ToolTip="Click to go to Whisper settings"/>
                                        <TextBlock x:Name="WhisperModelText" Text=" — tiny.en" 
                                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="5,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Llama Status - Clickable with warning -->
                                    <TextBlock Text="Llama:" Grid.Row="1" Grid.Column="0" Margin="0,5,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Margin="0,5,0,0">
                                        <TextBlock x:Name="LlamaStatusText" Text="Disabled" 
                                                   Foreground="{DynamicResource TextBrush}" Cursor="Hand"
                                                   MouseLeftButtonDown="LlamaStatus_Click"
                                                   ToolTipService.ToolTip="Click to go to Llama settings"/>
                                        <TextBlock x:Name="LlamaLoadLink" Text=" — Load now →" 
                                                   Foreground="#FFC107" Cursor="Hand" FontWeight="SemiBold"
                                                   MouseLeftButtonDown="LoadLlama_Click"
                                                   Visibility="Collapsed"
                                                   ToolTipService.ToolTip="Click to load Llama model now"/>
                                        <TextBlock x:Name="LlamaModelText" Text=" — qwen2.5" 
                                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="5,0,0,0"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>

                                    <!-- Microphone - Clickable -->
                                    <TextBlock Text="Mic:" Grid.Row="2" Grid.Column="0" Margin="0,5,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock x:Name="MicrophoneStatusText" Text="Default" Grid.Row="2" Grid.Column="1" Margin="0,5,0,0"
                                               Foreground="{DynamicResource TextBrush}" Cursor="Hand"
                                               MouseLeftButtonDown="MicrophoneStatus_Click"
                                               ToolTipService.ToolTip="Click to change microphone"/>

                                    <!-- Preset - Clickable -->
                                    <TextBlock Text="Preset:" Grid.Row="3" Grid.Column="0" Margin="0,5,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock x:Name="PresetStatusText" Text="Balanced" Grid.Row="3" Grid.Column="1" Margin="0,5,0,0"
                                               Foreground="{DynamicResource TextBrush}" Cursor="Hand"
                                               MouseLeftButtonDown="PresetStatus_Click"
                                               ToolTipService.ToolTip="Click to change preset"/>

                                    <!-- Hotkey - Clickable -->
                                    <TextBlock Text="Hotkey:" Grid.Row="4" Grid.Column="0" Margin="0,5,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock x:Name="HotkeyStatusText" Text="Ctrl+Shift+R" Grid.Row="4" Grid.Column="1" Margin="0,5,0,0"
                                               Foreground="{DynamicResource TextBrush}" Cursor="Hand"
                                               MouseLeftButtonDown="HotkeyStatus_Click"
                                               ToolTipService.ToolTip="Click to change hotkey"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="General Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Quick Presets -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Quick Presets" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           ToolTipService.ToolTip="One-click configuration for common use cases"/>
                                <TextBlock Text="Choose a preset to quickly configure optimal settings"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"
                                           ToolTipService.ToolTip="Each preset configures model size and other settings for a specific use case"/>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="PresetFastestBtn" Content="⚡ Fastest" 
                                            Click="PresetFastest_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Margin="0,0,10,0"
                                            ToolTipService.ToolTip="Fastest: Tiny model (~75MB), 8kHz audio, minimal post-processing. Best for quick dictation."/>
                                    <Button x:Name="PresetBalancedBtn" Content="⚖️ Balanced" 
                                            Click="PresetBalanced_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Margin="0,0,10,0"
                                            ToolTipService.ToolTip="Balanced: Base model (~150MB), 16kHz audio, standard formatting. Good balance of speed and accuracy."/>
                                    <Button x:Name="PresetAccurateBtn" Content="🎯 Most Accurate" 
                                            Click="PresetAccurate_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            ToolTipService.ToolTip="Most Accurate: Medium model (~1.5GB), 48kHz audio, full processing. Highest accuracy for important transcriptions."/>
                                </StackPanel>
                                <!-- Live Preview Panel -->
                                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6" 
                                        Padding="12" Margin="0,12,0,0" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock x:Name="CurrentPresetLabel" Text="Current: Balanced" 
                                                   FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}" FontSize="12"/>
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Model:" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,10,2"/>
                                            <TextBlock x:Name="PreviewModelText" Grid.Row="0" Grid.Column="1" Text="base" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Audio:" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,10,2"/>
                                            <TextBlock x:Name="PreviewAudioText" Grid.Row="1" Grid.Column="1" Text="16kHz" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Processing:" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,10,0"/>
                                            <TextBlock x:Name="PreviewProcessingText" Grid.Row="2" Grid.Column="1" Text="Standard" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Recording Settings -->
                        <Expander Header="Recording Settings" IsExpanded="True" Margin="0,20,0,0"
                                  Background="{DynamicResource CardBrush}" Padding="0">
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0">
                                <StackPanel>
                                    <!-- Recording Mode Explanation -->
                                    <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6" Padding="12" Margin="0,0,0,15"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <StackPanel>
                                            <TextBlock Text="Recording Modes" FontWeight="SemiBold" FontSize="12"
                                                       Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,8"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="• Push-to-talk (default):" FontWeight="Medium" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                                <TextBlock Text=" Hold hotkey to record, release to stop" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                <TextBlock Text="• Push-on, talk:" FontWeight="Medium" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                                <TextBlock Text=" Press once to start, press again to stop" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="• Push-off, talk:" FontWeight="Medium" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                                <TextBlock Text=" Press to start, auto-stop after silence" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="4,0,0,0"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                    
                                    <!-- Push-to-talk Toggle -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Push-to-talk mode" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="Hold hotkey to record, release to stop"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="PushToTalkCheckbox" Grid.Column="1"
                                                  Style="{DynamicResource ToggleSwitchStyle}"
                                                  Checked="PushToTalkCheckbox_Changed" Unchecked="PushToTalkCheckbox_Changed"
                                                  ToolTipService.ToolTip="Hold the hotkey to record, release to transcribe. Best for privacy."/>
                                    </Grid>
                                    
                                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,15,0,15"/>
                                    
                                    <!-- Hotkey Input -->
                                    <StackPanel x:Name="HotkeyInputPanel">
                                        <TextBlock Text="Hotkey" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <TextBlock Text="Ctrl+Shift+" Foreground="{DynamicResource TextBrush}"
                                                       VerticalAlignment="Center"/>
                                            <TextBox x:Name="HotkeyTriggerTextBox" Width="40" MaxLength="1"
                                                     TextAlignment="Center" TextChanged="HotkeyTriggerTextBox_TextChanged"
                                                     VerticalAlignment="Center"
                                                     ToolTipService.ToolTip="Press a letter or number key to set the hotkey"/>
                                        </StackPanel>
                                        <TextBlock Text="Type a single letter or number. The Ctrl+Shift modifiers are fixed."
                                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,10,0,0"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <!-- Theme Configuration -->
                        <Expander Header="Application Theme" IsExpanded="True" Margin="0,10,0,0"
                                  Background="{DynamicResource CardBrush}" Padding="0">
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Application Theme" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               ToolTipService.ToolTip="Choose your preferred color scheme for the application"/>
                                    <TextBlock Text="Choose between light and dark visual themes"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"/>
                                    <ComboBox x:Name="ThemeComboBox" Width="220" HorizontalAlignment="Left"
                                              SelectionChanged="ThemeComboBox_SelectionChanged"
                                              Background="{DynamicResource CardBrush}"
                                              Foreground="{DynamicResource TextBrush}"
                                              ToolTipService.ToolTip="Select Light, Dark, or one of the colorful themes">
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="16" CornerRadius="2" Margin="0,0,8,0" BorderBrush="#DDD" BorderThickness="1">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                            <GradientStop Color="#FFFFFF" Offset="0"/>
                                                            <GradientStop Color="#F5F5F5" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <TextBlock Text="Light"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="16" CornerRadius="2" Margin="0,0,8,0" BorderBrush="#444" BorderThickness="1" Background="#252526"/>
                                                <TextBlock Text="Dark"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="16" CornerRadius="2" Margin="0,0,8,0" BorderBrush="#5E81AC" BorderThickness="1" Background="#2E3440"/>
                                                <TextBlock Text="Nord"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="16" CornerRadius="2" Margin="0,0,8,0" BorderBrush="#BD93F9" BorderThickness="1" Background="#282A36"/>
                                                <TextBlock Text="Dracula"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="16" CornerRadius="2" Margin="0,0,8,0" BorderBrush="#FABD2F" BorderThickness="1" Background="#282828"/>
                                                <TextBlock Text="Gruvbox"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="16" CornerRadius="2" Margin="0,0,8,0" BorderBrush="#F92672" BorderThickness="1" Background="#272822"/>
                                                <TextBlock Text="Monokai"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                        <ComboBoxItem>
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="24" Height="16" CornerRadius="2" Margin="0,0,8,0" BorderBrush="#FF79C6" BorderThickness="1" Background="#1A1A2E"/>
                                                <TextBlock Text="Synthwave"/>
                                            </StackPanel>
                                        </ComboBoxItem>
                                    </ComboBox>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <!-- Download Paths -->
                        <Expander x:Name="DownloadPathsExpander" Header="Model Download Paths" Margin="0,10,0,0"
                                  Background="{DynamicResource CardBrush}" Padding="0"
                                  Expanded="DownloadPathsExpander_Expanded" Collapsed="DownloadPathsExpander_Collapsed">
                            <StackPanel>
                                <!-- Whisper Model Download Path -->
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20,20,20,10">
                                    <StackPanel>
                                        <TextBlock Text="Whisper Model Download Path" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   ToolTipService.ToolTip="Where Whisper AI models are stored. Restart required for changes to take effect."/>
                                        <TextBlock Text="Custom folder for Whisper models (.bin files)"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="ModelDownloadPathTextBox" Grid.Column="0" 
                                                     VerticalContentAlignment="Center" Padding="5"
                                                     TextChanged="ModelDownloadPathTextBox_TextChanged"
                                                     ToolTipService.ToolTip="Click Browse to select a folder"/>
                                            <TextBlock x:Name="WhisperPathValidIcon" Grid.Column="1" Text="✓" FontSize="16" 
                                                       Foreground="#4ADE80" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed"
                                                       ToolTipService.ToolTip="Path is valid"/>
                                            <TextBlock x:Name="WhisperPathWarningIcon" Grid.Column="1" Text="⚠" FontSize="16" 
                                                       Foreground="#FBBF24" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed"/>
                                            <Border x:Name="WhisperModelCountBadge" Grid.Column="2" Background="{DynamicResource AccentBrush}"  
                                                    CornerRadius="10" Padding="8,3" Margin="8,0,0,0" Visibility="Collapsed">
                                                <TextBlock x:Name="WhisperModelCountText" Text="0 models" FontSize="11" Foreground="White"/>
                                            </Border>
                                            <Button x:Name="BrowseDownloadPathBtn" Content="Browse..." Grid.Column="3" 
                                                    Click="BrowseDownloadPath_Click" Margin="10,0,0,0" MinWidth="80"
                                                    Style="{DynamicResource SecondaryButtonStyle}"/>
                                        </Grid>
                                        <!-- Compact Path Summary -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Border x:Name="WhisperPathSummaryBadge" Background="{DynamicResource AccentBrush}" 
                                                    CornerRadius="10" Padding="8,3" Visibility="Collapsed">
                                                <TextBlock x:Name="WhisperPathSummaryText" Text="0 models" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <!-- Llama Model Download Path -->
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20,10,20,20">
                                    <StackPanel>
                                        <TextBlock Text="Llama Model Download Path" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   ToolTipService.ToolTip="Where Llama text formatting models are stored. Restart required for changes to take effect."/>
                                        <TextBlock Text="Custom folder for GGUF models (.gguf files)"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"/>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="LlamaDownloadPathTextBox" Grid.Column="0" 
                                                     VerticalContentAlignment="Center" Padding="5"
                                                     TextChanged="LlamaDownloadPathTextBox_TextChanged"
                                                     ToolTipService.ToolTip="Click Browse to select a folder"/>
                                            <TextBlock x:Name="LlamaPathValidIcon" Grid.Column="1" Text="✓" FontSize="16" 
                                                       Foreground="#4ADE80" VerticalAlignment="Center" Margin="8,0,0,0" Visibility="Collapsed"
                                                       ToolTipService.ToolTip="Path is valid"/>
                                            <Border x:Name="LlamaModelCountBadge" Grid.Column="2" Background="{DynamicResource AccentBrush}" 
                                                    CornerRadius="10" Padding="8,3" Margin="8,0,0,0" Visibility="Collapsed">
                                                <TextBlock x:Name="LlamaModelCountText" Text="0 models" FontSize="11" Foreground="White"/>
                                            </Border>
                                            <Button x:Name="BrowseLlamaDownloadPathBtn" Content="Browse..." Grid.Column="3" 
                                                    Click="BrowseLlamaDownloadPath_Click" Margin="10,0,0,0" MinWidth="80"
                                                    Style="{DynamicResource SecondaryButtonStyle}"/>
                                        </Grid>
                                        <!-- Compact Path Summary -->
                                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                            <Border x:Name="LlamaPathSummaryBadge" Background="{DynamicResource AccentBrush}" 
                                                    CornerRadius="10" Padding="8,3" Visibility="Collapsed">
                                                <TextBlock x:Name="LlamaPathSummaryText" Text="0 models" FontSize="11" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander> 
                        <!-- System Integration -->
                        <Expander Header="System Integration" IsExpanded="True" Margin="0,10,0,0"
                                  Background="{DynamicResource CardBrush}" Padding="0">
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0">
                                <StackPanel>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Launch at login" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="Start the app automatically when you log in to Windows"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="LaunchAtLoginCheckbox" Grid.Column="1"
                                                  Style="{DynamicResource ToggleSwitchStyle}"
                                                  Checked="LaunchAtLoginCheckbox_Changed" Unchecked="LaunchAtLoginCheckbox_Changed"
                                                  ToolTipService.ToolTip="Automatically start whisperMeOff when you log in to Windows"/>
                                    </Grid>
                                    <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,15,0,15"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Minimize to system tray" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextBrush}"/>
                                            <TextBlock Text="Keep running in the background when window is closed"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,3,0,0"/>
                                        </StackPanel>
                                        <CheckBox x:Name="MinimizeToTrayCheckbox" Grid.Column="1"
                                                  Style="{DynamicResource ToggleSwitchStyle}"
                                                  Checked="MinimizeToTrayCheckbox_Changed" Unchecked="MinimizeToTrayCheckbox_Changed"
                                                  ToolTipService.ToolTip="Keep the app running in the system tray instead of the taskbar"/>
                                    </Grid>
                                </StackPanel>
                            </Border>
                        </Expander>

                        <!-- Clipboard Settings -->
                        <Expander Header="Clipboard Settings" IsExpanded="False" Margin="0,10,0,0"
                                  Background="{DynamicResource CardBrush}" Padding="0" Visibility="Collapsed">
                            <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="Clipboard Settings" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               ToolTipService.ToolTip="Configure how clipboard content is handled after transcription"/>
                                    <CheckBox x:Name="RestoreClipboardCheckbox" Content="Restore previous clipboard after paste"
                                              Margin="0,10,0,0"
                                              Checked="RestoreClipboardCheckbox_Changed" Unchecked="RestoreClipboardCheckbox_Changed"
                                              ToolTipService.ToolTip="Automatically restore your previous clipboard content after the transcribed text is pasted"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <TextBlock Text="Restore delay (ms):" Foreground="{DynamicResource TextBrush}" 
                                                   VerticalAlignment="Center" Margin="0,0,10,0"
                                                   ToolTipService.ToolTip="How long to wait before restoring the clipboard (in milliseconds)"/>
                                        <TextBox x:Name="ClipboardDelayTextBox" Width="80" TextAlignment="Center"
                                                 TextChanged="ClipboardDelayTextBox_TextChanged"
                                                 ToolTipService.ToolTip="Delay in milliseconds before restoring clipboard"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Audio Tab -->
            <TabItem Header="Audio">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Audio Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Microphone Selection -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Microphone" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"
                                               ToolTipService.ToolTip="Select which microphone to use for recording"/>
                                    <Button x:Name="RefreshMicrophonesBtn" Grid.Column="1" Content="🔄" 
                                            Click="RefreshMicrophones_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}" 
                                            Padding="8,4" ToolTipService.ToolTip="Refresh device list"/>
                                </Grid>
                                <ComboBox x:Name="MicrophoneComboBox" Margin="0,10,0,0"
                                          SelectionChanged="MicrophoneComboBox_SelectionChanged"
                                          ToolTipService.ToolTip="Choose your preferred recording device"/>
                                
                                <!-- Device Info -->
                                <TextBlock x:Name="MicrophoneDeviceInfo" Margin="0,8,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"
                                           Visibility="Collapsed"/>
                                
                                <!-- Pre-Recording Buffer Toggle -->
                                <Grid Margin="0,15,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Pre-recording buffer" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="Capture 300ms before trigger to avoid clipping first word"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,3,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                    <CheckBox x:Name="PreBufferCheckbox" Grid.Column="1"
                                              Style="{DynamicResource ToggleSwitchStyle}"
                                              Checked="PreBufferCheckbox_Changed" Unchecked="PreBufferCheckbox_Changed"
                                              ToolTipService.ToolTip="When enabled, captures audio before you release the trigger so the first word isn't clipped"/>
                                </Grid>
                                
                                <!-- Audio Diagnostics -->
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15" Margin="0,15,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Audio Diagnostics" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                                        <TextBlock x:Name="AudioDiagnosticsText" 
                                                   Foreground="{DynamicResource SecondaryTextBrush}" 
                                                   FontSize="12" TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Whisper Tab -->
            <TabItem Header="Whisper">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Whisper Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Language -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Language" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           ToolTipService.ToolTip="Select the language you'll be speaking. Auto Detect will identify the language automatically."/>
                                <!-- Auto Detect Toggle -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="Auto language detection" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="Automatically detect spoken language"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,3,0,0"/>
                                    </StackPanel>
                                    <CheckBox x:Name="AutoDetectLanguageCheckbox" Grid.Column="1"
                                              IsChecked="True"
                                              Style="{DynamicResource ToggleSwitchStyle}"
                                              Checked="AutoDetectLanguageCheckbox_Changed" Unchecked="AutoDetectLanguageCheckbox_Changed"/>
                                </Grid>
                                <!-- Language Dropdown (shown when auto-detect is OFF) -->
                                <StackPanel x:Name="LanguageDropdownPanel" Margin="0,10,0,0" Visibility="Collapsed">
                                    <TextBlock Text="Target language:" Foreground="{DynamicResource TextBrush}" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="LanguageComboBox"
                                              SelectionChanged="LanguageComboBox_SelectionChanged"
                                              ToolTipService.ToolTip="Choose your target language">
                                        <ComboBoxItem Content="English" Tag="en" IsSelected="True"/>
                                        <ComboBoxItem Content="Spanish" Tag="es"/>
                                        <ComboBoxItem Content="French" Tag="fr"/>
                                        <ComboBoxItem Content="German" Tag="de"/>
                                        <ComboBoxItem Content="Italian" Tag="it"/>
                                        <ComboBoxItem Content="Portuguese" Tag="pt"/>
                                        <ComboBoxItem Content="Russian" Tag="ru"/>
                                        <ComboBoxItem Content="Chinese" Tag="zh"/>
                                        <ComboBoxItem Content="Japanese" Tag="ja"/>
                                        <ComboBoxItem Content="Korean" Tag="ko"/>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Translate -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <CheckBox x:Name="TranslateCheckbox" Content="Translate to English"
                                          Checked="TranslateCheckbox_Changed" Unchecked="TranslateCheckbox_Changed"
                                          ToolTipService.ToolTip="Automatically translate non-English speech to English"
                                          Style="{DynamicResource ToggleSwitchStyle}"/>
                            </StackPanel>
                        </Border>

                        <!-- Model Selection -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Model" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           ToolTipService.ToolTip="Select which Whisper AI model to use for transcription"/>
                                <!-- Model Info Row -->
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock x:Name="ModelPathText" Text="No model selected"
                                                   Foreground="{DynamicResource TextBrush}" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   ToolTipService.ToolTip="Path to the currently selected model file"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                            <Border x:Name="ModelSizeBadge" Background="{DynamicResource ValidBadgeBrush}" 
                                                    CornerRadius="8" Padding="6,2" Margin="0,0,5,0" Visibility="Collapsed">
                                                <TextBlock x:Name="ModelSizeText" Text="0 MB" FontSize="10" Foreground="White"/>
                                            </Border>
                                            <Border x:Name="ModelSampleRateBadge" Background="{DynamicResource AccentBrush}" 
                                                    CornerRadius="8" Padding="6,2" Visibility="Collapsed">
                                                <TextBlock x:Name="ModelSampleRateText" Text="16kHz" FontSize="10" Foreground="White"/>
                                            </Border>
                                        </StackPanel>
                                    </StackPanel>
                                    <Border x:Name="ModelValidationBadge" Grid.Column="1" 
                                            CornerRadius="8" Padding="8,4" Visibility="Collapsed" VerticalAlignment="Center">
                                        <TextBlock x:Name="ModelValidationText" Text="Valid" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                                    </Border>
                                </Grid>
                                <!-- Button Row -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Content="Select Model File..." Click="SelectModel_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            ToolTipService.ToolTip="Browse for a .bin model file"/>
                                    <Button x:Name="ValidateModelBtn" Content="Validate" Click="ValidateModel_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}" Margin="10,0,0,0"
                                            ToolTipService.ToolTip="Validate the selected model file"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Download Models -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Download Models" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           ToolTipService.ToolTip="Download different Whisper model sizes. Larger models are more accurate but slower."/>
                                <TextBlock Text="Download different Whisper model sizes"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"
                                           ToolTipService.ToolTip="Tiny: fastest, least accurate. Large: slowest, most accurate."/>

                                <StackPanel x:Name="DownloadModelsPanel">
                                    <!-- Header Row -->
                                    <Grid Margin="0,0,0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Model" Grid.Column="0" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                        <TextBlock Text="Size" Grid.Column="1" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                        <TextBlock Text="Speed" Grid.Column="2" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                        <TextBlock Text="Accuracy" Grid.Column="3" FontWeight="SemiBold" Foreground="{DynamicResource TextBrush}" FontSize="11"/>
                                    </Grid>
                                    <!-- Tiny -->
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Tiny" Grid.Column="0" Foreground="{DynamicResource TextBrush}"
                                                   ToolTipService.ToolTip="~75MB - Fastest but least accurate. Good for quick dictation."/>
                                        <TextBlock Text="~75MB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <TextBlock Text="~60x" Grid.Column="2" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" ToolTipService.ToolTip="Real-time factor - higher is faster"/>
                                        <TextBlock Text="Low" Grid.Column="3" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <Button x:Name="DownloadTinyBtn" Content="Download" Grid.Column="5" Click="DownloadTiny_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"/>
                                    </Grid>
                                    <!-- Base -->
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Base" Grid.Column="0" Foreground="{DynamicResource TextBrush}"
                                                   ToolTipService.ToolTip="~150MB - Good balance of speed and accuracy for most use cases."/>
                                        <TextBlock Text="~150MB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <TextBlock Text="~30x" Grid.Column="2" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" ToolTipService.ToolTip="Real-time factor - higher is faster"/>
                                        <TextBlock Text="Medium" Grid.Column="3" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <Button x:Name="DownloadBaseBtn" Content="Download" Grid.Column="5" Click="DownloadBase_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"/>
                                    </Grid>
                                    <!-- Small -->
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Small" Grid.Column="0" Foreground="{DynamicResource TextBrush}"
                                                   ToolTipService.ToolTip="~500MB - Better accuracy than Base, still relatively fast."/>
                                        <TextBlock Text="~500MB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <TextBlock Text="~15x" Grid.Column="2" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" ToolTipService.ToolTip="Real-time factor - higher is faster"/>
                                        <TextBlock Text="High" Grid.Column="3" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <Button x:Name="DownloadSmallBtn" Content="Download" Grid.Column="5" Click="DownloadSmall_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"/>
                                    </Grid>
                                    <!-- Medium -->
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Medium" Grid.Column="0" Foreground="{DynamicResource TextBrush}"
                                                   ToolTipService.ToolTip="~1.5GB - High accuracy, slower processing. Recommended for important transcriptions."/>
                                        <TextBlock Text="~1.5GB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <TextBlock Text="~6x" Grid.Column="2" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" ToolTipService.ToolTip="Real-time factor - higher is faster"/>
                                        <TextBlock Text="Very High" Grid.Column="3" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <Button x:Name="DownloadMediumBtn" Content="Download" Grid.Column="5" Click="DownloadMedium_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"/>
                                    </Grid>
                                    <!-- Large -->
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="70"/>
                                            <ColumnDefinition Width="60"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="50"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Large" Grid.Column="0" Foreground="{DynamicResource TextBrush}"
                                                   ToolTipService.ToolTip="~3GB - Highest accuracy, slowest processing. Requires powerful hardware."/>
                                        <TextBlock Text="~3GB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <TextBlock Text="~2x" Grid.Column="2" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" ToolTipService.ToolTip="Real-time factor - higher is faster"/>
                                        <TextBlock Text="Highest" Grid.Column="3" Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11"/>
                                        <Button x:Name="DownloadLargeBtn" Content="Download" Grid.Column="5" Click="DownloadLarge_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}" Padding="12,6"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Download Progress -->
                                <ProgressBar x:Name="DownloadProgressBar" Height="8" Margin="0,15,0,0"
                                             Visibility="Collapsed" Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock x:Name="DownloadStatusText" Margin="0,5,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Llama Tab -->
            <TabItem Header="Llama">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Llama Text Formatting" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Enable Llama (consolidated card) -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <!-- Text Formatting Section -->
                                <CheckBox x:Name="LlamaEnableCheckbox" Content="Enable Llama text formatting"
                                          Checked="LlamaEnableCheckbox_Changed" Unchecked="LlamaEnableCheckbox_Changed"
                                          ToolTipService.ToolTip="Use AI to automatically format and improve transcribed text (capitalization, punctuation, etc.)"
                                          Style="{DynamicResource ToggleSwitchStyle}"/>
                                <TextBlock Text="Automatically format transcribed text with Llama"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"
                                           ToolTipService.ToolTip="When enabled, Llama will process your transcriptions to add proper capitalization, punctuation, and formatting"/>
                                
                                <!-- Divider -->
                                <Rectangle Height="1" Fill="{DynamicResource BorderBrush}" Margin="0,20,0,20"/>
                                
                                <!-- Translation Section -->
                                <CheckBox x:Name="LlamaTranslateCheckbox" Content="Enable Llama translation"
                                          Checked="LlamaTranslateCheckbox_Changed" Unchecked="LlamaTranslateCheckbox_Changed"
                                          ToolTipService.ToolTip="Use AI to translate transcribed text to a different language"
                                          Style="{DynamicResource ToggleSwitchStyle}"/>
                                <TextBlock Text="Translate transcribed text using Llama (after Whisper transcription)"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"
                                           ToolTipService.ToolTip="When enabled, Llama will translate the transcribed text. Useful when Whisper's built-in translation doesn't work well for your language pair."/>
                                
                                <!-- Language Selection -->
                                <StackPanel x:Name="LlamaTranslationOptionsPanel" Orientation="Horizontal" Margin="0,15,0,0"
                                            Visibility="{Binding ElementName=LlamaTranslateCheckbox, Path=IsChecked, Converter={StaticResource BoolToVisibilityConverter}}">
                                    <TextBlock Text="Translate to:" VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextBrush}" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="LlamaTargetLanguageComboBox" Width="150"
                                              SelectionChanged="LlamaTargetLanguageComboBox_Changed">
                                        <ComboBoxItem Content="English (en)" Tag="en"/>
                                        <ComboBoxItem Content="Spanish (es)" Tag="es"/>
                                        <ComboBoxItem Content="French (fr)" Tag="fr"/>
                                        <ComboBoxItem Content="German (de)" Tag="de"/>
                                        <ComboBoxItem Content="Italian (it)" Tag="it"/>
                                        <ComboBoxItem Content="Portuguese (pt)" Tag="pt"/>
                                        <ComboBoxItem Content="Russian (ru)" Tag="ru"/>
                                        <ComboBoxItem Content="Chinese (zh)" Tag="zh"/>
                                        <ComboBoxItem Content="Japanese (ja)" Tag="ja"/>
                                        <ComboBoxItem Content="Korean (ko)" Tag="ko"/>
                                        <ComboBoxItem Content="Arabic (ar)" Tag="ar"/>
                                        <ComboBoxItem Content="Hindi (hi)" Tag="hi"/>
                                        <ComboBoxItem Content="Dutch (nl)" Tag="nl"/>
                                        <ComboBoxItem Content="Polish (pl)" Tag="pl"/>
                                        <ComboBoxItem Content="Turkish (tr)" Tag="tr"/>
                                        <ComboBoxItem Content="Vietnamese (vi)" Tag="vi"/>
                                    </ComboBox>
                                </StackPanel>
                                <TextBlock x:Name="LlamaTranslationDescription" Text="Select the target language for translation"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0" FontSize="11"
                                           ToolTipService.ToolTip="Choose the language to translate transcribed text to"/>
                            </StackPanel>
                        </Border>

                        <!-- Model Selection -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Model" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock x:Name="LlamaModelPathText" Text="No model selected"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,0,0"/>
                                
                                <!-- Model Metadata Badges -->
                                <StackPanel x:Name="LlamaModelBadgesPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                                    <Border x:Name="QuantizationBadge" Background="{DynamicResource InfoBadgeBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                            ToolTipService.ToolTip="Quantization: How the model is compressed. FP16 = full precision, Q4-Q8 = progressively more compressed (smaller file, less RAM, slightly less accurate)">
                                        <TextBlock x:Name="QuantizationBadgeText" Text="" FontSize="11" Foreground="White"/>
                                    </Border>
                                    <Border x:Name="SizeBadge" Background="{DynamicResource ValidBadgeBrush}" CornerRadius="4" Padding="6,2" Margin="0,0,6,0"
                                            ToolTipService.ToolTip="Model size in billions of parameters. Larger = more accurate but requires more RAM (approximately 2GB per 1B parameters in FP16)">
                                        <TextBlock x:Name="SizeBadgeText" Text="" FontSize="11" Foreground="White"/>
                                    </Border>
                                    <Border x:Name="RAMBadge" Background="{DynamicResource AccentBrush}" CornerRadius="4" Padding="6,2">
                                        <TextBlock x:Name="RAMBadgeText" Text="" FontSize="11" Foreground="White"/>
                                    </Border>
                                </StackPanel>
                                
                                <Button Content="Select Model File..." Click="SelectLlamaModel_Click"
                                        Style="{DynamicResource SecondaryButtonStyle}" Margin="0,10,0,0"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Download from HuggingFace -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Download from HuggingFace" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           ToolTipService.ToolTip="Download Llama models from HuggingFace model hub"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="HuggingFaceModelIdTextBox" Grid.Column="0"
                                             TextChanged="HuggingFaceModelIdTextBox_TextChanged"
                                             ToolTipService.ToolTip="Enter the model ID from huggingface.co (e.g., TheBloke/Llama-2-7B-Chat-GGUF)"/>
                                    <TextBlock x:Name="ValidationIcon" Grid.Column="1" Text="" FontSize="16" 
                                               Margin="8,0,0,0" VerticalAlignment="Center"/>
                                </Grid>
                                <TextBlock Text="Find models at huggingface.co/models — search for GGUF quantized models"
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,5,0,0"
                                           TextWrapping="Wrap"
                                           ToolTipService.ToolTip="Look for GGUF format models for best compatibility"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button Click="DownloadLlamaModel_Click"
                                            Style="{DynamicResource PrimaryButtonStyle}">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="Download Model" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                    <Button Click="BrowseHuggingFaceLlama_Click"
                                            Style="{DynamicResource PrimaryButtonStyle}" Margin="10,0,0,0">
                                        <StackPanel Orientation="Horizontal">
                                            <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z" 
                                                  Fill="White" Width="16" Height="16" Stretch="Uniform" Margin="0,0,6,0"/>
                                            <TextBlock Text="Browse Models" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>

                                <!-- Download Progress for Llama -->
                                <ProgressBar x:Name="LlamaDownloadProgressBar" Height="8" Margin="0,15,0,0"
                                             Visibility="Collapsed" Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock x:Name="LlamaDownloadStatusText" Margin="0,5,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Visibility="Collapsed"/>

                                <!-- HuggingFace Token -->
                                <TextBlock Text="HuggingFace Token (for private models)" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,20,0,0"
                                           ToolTipService.ToolTip="Required to access private or gated models on HuggingFace"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <PasswordBox x:Name="HuggingFaceTokenBox" Grid.Column="0"
                                                PasswordChanged="HuggingFaceTokenBox_PasswordChanged"
                                                Background="{DynamicResource CardBrush}"
                                                Foreground="{DynamicResource TextBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                Padding="10,8"
                                                CaretBrush="{DynamicResource TextBrush}"
                                                ToolTipService.ToolTip="Your HuggingFace access token. Get it from huggingface.co/settings/tokens"/>
                                    <TextBox x:Name="HuggingFaceTokenTextBox" Grid.Column="0"
                                             Visibility="Collapsed"
                                             TextChanged="HuggingFaceTokenTextBox_TextChanged"
                                             Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource TextBrush}"
                                             BorderBrush="{DynamicResource BorderBrush}"
                                             BorderThickness="1"
                                             Padding="10,8"
                                             CaretBrush="{DynamicResource TextBrush}"
                                             ToolTipService.ToolTip="Your HuggingFace access token. Get it from huggingface.co/settings/tokens"/>
                                    <Button x:Name="ToggleHuggingFaceTokenBtn" Grid.Column="1" Content="👁"
                                            Click="ToggleHuggingFaceToken_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Width="70" Height="36" Margin="5,0,0,0"
                                            FontSize="15"
                                            ToolTipService.ToolTip="Show/Hide token"/>
                                </Grid>
                                <TextBlock Text="Required for gated/private models. Get yours at huggingface.co/settings/tokens"
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Vocabulary Tab -->
            <TabItem Header="Vocabulary">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Custom Vocabulary" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Add words or phrases to improve recognition accuracy"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,20"
                                   ToolTipService.ToolTip="Improve transcription accuracy by adding domain-specific words"/>

                        <!-- Custom Vocabulary Input -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Word List" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}"
                                                   ToolTipService.ToolTip="Enter words or phrases that Whisper should recognize"/>
                                        <TextBlock Text="Add words or phrases to improve recognition"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"
                                                   ToolTipService.ToolTip="Whisper will be more likely to correctly recognize these words"/>
                                    </StackPanel>
                                    <TextBlock x:Name="WordCountText" Grid.Column="1" 
                                               Text="0 words" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}" 
                                               VerticalAlignment="Top" Margin="0,5,0,0"/>
                                </Grid>
                                
                                <!-- Hidden storage for vocabulary -->
                                <TextBox x:Name="CustomVocabularyTextBox" Visibility="Collapsed"
                                         TextChanged="CustomVocabularyTextBox_TextChanged"/>
                                
                                <!-- Filter word list -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="WordFilterTextBox" 
                                             Padding="8,6" MinWidth="200"
                                             ToolTipService.ToolTip="Filter words..."
                                             TextChanged="WordFilterTextBox_TextChanged"/>
                                </StackPanel>
                                
                                <!-- Chip Input Area -->
                                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6" Padding="8">
                                    <StackPanel>
                                        <!-- Word Chips Display -->
                                        <WrapPanel x:Name="WordChipsPanel"/>
                                        
                                        <!-- Input Field -->
                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox x:Name="AddWordTextBox" 
                                                     Padding="8,6"
                                                     KeyDown="AddWordTextBox_KeyDown"
                                                     ToolTipService.ToolTip="Type a word and press Enter to add"/>
                                            <Button Grid.Column="1" Content="Add" 
                                                    Click="AddWord_Click"
                                                    Style="{DynamicResource PrimaryButtonStyle}" 
                                                    Margin="8,0,0,0" Padding="12,6"/>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                                
                                <TextBlock Text="Type a word or phrase and press Enter or click Add. Click X on a chip to remove."
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,10,0,0"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <!-- Suggested For You -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Suggested for you" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Click to add common dev/tech terms to your vocabulary"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10" FontSize="11"/>
                                
                                <!-- Suggested chips -->
                                <WrapPanel x:Name="SuggestedWordsPanel">
                                    <Button x:Name="SuggestedDocker" Content="Docker" Tag="Docker" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedKubectl" Content="kubectl" Tag="kubectl" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedJSON" Content="JSON" Tag="JSON" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedAsync" Content="async" Tag="async" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedEnum" Content="enum" Tag="enum" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedAPI" Content="API" Tag="API" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedSDK" Content="SDK" Tag="SDK" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedAWS" Content="AWS" Tag="AWS" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedKubernetes" Content="Kubernetes" Tag="Kubernetes" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedCICD" Content="CI/CD" Tag="CI/CD" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedMiddleware" Content="middleware" Tag="middleware" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedBool" Content="bool" Tag="bool" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedNullable" Content="nullable" Tag="nullable" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedWebSocket" Content="WebSocket" Tag="WebSocket" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedLocalhost" Content="localhost" Tag="localhost" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                    <Button x:Name="SuggestedGit" Content="git" Tag="git" Click="AddSuggestedWord_Click"
                                            Style="{StaticResource ChipButtonStyle}" Margin="0,0,8,8"/>
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <!-- Section Divider -->
                        <StackPanel Margin="0,25,0,15">
                            <TextBlock Text="▌ Post-Processing" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,0,5"/>
                            <Rectangle Height="1" Fill="{DynamicResource BorderBrush}"/>
                        </StackPanel>

                        <!-- Word Replacements -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Word Replacements" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"
                                           ToolTipService.ToolTip="Automatically replace spoken words with different text after transcription"/>
                                <TextBlock Text="Replace spoken words with different text after transcription"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"
                                           ToolTipService.ToolTip="Useful for fixing common mishearings or customizing output"/>

                                <!-- Add new replacement row -->
                                <Grid Margin="0,0,0,10">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <!-- Labels -->
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Spoken:" FontSize="11" 
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Replace with:" FontSize="11" 
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,3"/>
                                    
                                    <!-- Input fields -->
                                    <TextBox x:Name="NewReplacementSourceBox" Grid.Row="1" Grid.Column="0" 
                                             VerticalContentAlignment="Center" Padding="8,6" Margin="0,0,5,0"
                                             ToolTipService.ToolTip="When you say..." Text="Ken Kilty"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text=" → " 
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               VerticalAlignment="Center" Margin="5,0"/>
                                    <TextBox x:Name="NewReplacementTargetBox" Grid.Row="1" Grid.Column="2" 
                                             VerticalContentAlignment="Center" Padding="8,6" Margin="5,0,5,0"
                                             ToolTipService.ToolTip="Replace with..." Text="Ken FagBoi Kitly the 3rd"/>
                                    <Button x:Name="AddReplacementBtn" Grid.Row="1" Grid.Column="3" Content="Add" 
                                            Click="AddReplacement_Click"
                                            Style="{DynamicResource PrimaryButtonStyle}" Padding="15,6" Margin="5,0,0,0"/>
                                </Grid>

                                <!-- Filter replacements -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,5">
                                    <TextBlock Text="🔍" FontSize="14" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                    <TextBox x:Name="ReplacementFilterTextBox"
                                             Padding="8,6" MinWidth="200"
                                             ToolTipService.ToolTip="Filter replacements..."
                                             TextChanged="ReplacementFilterTextBox_TextChanged"/>
                                </StackPanel>

                                <!-- Replacements List -->
                                <ListBox x:Name="ReplacementsListBox" 
                                         Background="Transparent" BorderThickness="0"
                                         MaxHeight="200"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,3">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <!-- Drag handle -->
                                                <TextBlock Grid.Column="0" Text="⠿" 
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center" Margin="0,0,8,0"
                                                           Cursor="Hand" ToolTipService.ToolTip="Drag to reorder"/>
                                                
                                                <TextBlock Grid.Column="1" Text="{Binding Source}" 
                                                           Foreground="{DynamicResource TextBrush}"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text=" → " 
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           VerticalAlignment="Center" Margin="5,0"/>
                                                
                                                <!-- Replacement with light blue background -->
                                                <Border Grid.Column="3" Background="#E3F2FD" CornerRadius="3" Padding="6,2" Margin="0,0,5,0">
                                                    <TextBlock Text="{Binding Replacement}" 
                                                               Foreground="#1565C0"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                                
                                                <!-- Case sensitive toggle -->
                                                <ToggleButton x:Name="CaseToggle" Grid.Column="4" 
                                                             Width="36" Height="22"
                                                             IsChecked="{Binding CaseSensitive}"
                                                             Margin="0,0,3,0"
                                                             ToolTipService.ToolTip="Case sensitive match">
                                                    <TextBlock Text="Aa" FontSize="10" FontWeight="Bold"/>
                                                </ToggleButton>
                                                <!-- Regex toggle -->
                                                <ToggleButton x:Name="RegexToggle" Grid.Column="5" 
                                                             Width="36" Height="22"
                                                             IsChecked="{Binding IsRegex}"
                                                             Margin="0,0,10,0"
                                                             ToolTipService.ToolTip="Use regex pattern">
                                                    <TextBlock Text=".*" FontSize="10" FontWeight="Bold"/>
                                                </ToggleButton>
                                                
                                                <Button Grid.Column="7" Content="✕" 
                                                        Click="RemoveReplacement_Click"
                                                        Tag="{Binding Source}"
                                                        Style="{DynamicResource SecondaryButtonStyle}" 
                                                        Padding="8,2"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Test replacements - Live Preview -->
                                <Border Background="{DynamicResource BackgroundBrush}" CornerRadius="6" Padding="15" Margin="0,15,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Test replacements (live preview)" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource TextBrush}" Margin="0,0,0,8"/>
                                        
                                        <TextBlock Text="Input:" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4"/>
                                        <TextBox x:Name="TestReplacementInput" Grid.Row="0"
                                                 Text=""
                                                 Padding="8" MinHeight="50" TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 TextChanged="TestReplacementInput_TextChanged"/>
                                        
                                        <TextBlock Text="Output:" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,12,0,4"/>
                                        <TextBox x:Name="TestReplacementOutput" Grid.Row="1"
                                                 IsReadOnly="True" Padding="8" MinHeight="50" TextWrapping="Wrap"
                                                 Background="{DynamicResource CardBrush}"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="History">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search with live filtering -->
                    <Grid Grid.Row="0">
                        <TextBox x:Name="SearchTextBox" 
                                 TextChanged="SearchTextBox_TextChanged"
                                 Style="{DynamicResource SearchTextBoxStyle}"/>
                        <TextBlock Text="Search transcriptions…" 
                                   IsHitTestVisible="False"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   VerticalAlignment="Center" Margin="10,0,0,0"
                                   Visibility="{Binding Text.Length, ElementName=SearchTextBox, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                    </Grid>

                    <!-- History List with grouping -->
                    <Grid Grid.Row="1">
                        <ListBox x:Name="HistoryListBox" Margin="0,10,0,0"
                                 Background="Transparent" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionMode="Extended">
                            <ListBox.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.HeaderTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBrush}" 
                                                    CornerRadius="6" Padding="12,8" Margin="0,8,0,4">
                                                <TextBlock Text="{Binding Name}" 
                                                           FontWeight="SemiBold" 
                                                           FontSize="13"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                        </DataTemplate>
                                    </GroupStyle.HeaderTemplate>
                                </GroupStyle>
                            </ListBox.GroupStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="CardBorder" 
                                            Background="{DynamicResource CardBrush}" 
                                            CornerRadius="8" Padding="12" Margin="0,4"
                                            BorderThickness="1"
                                            BorderBrush="Transparent"
                                            MouseLeftButtonDown="CardBorder_MouseLeftButtonDown">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            
                                            <StackPanel Grid.Column="0">
                                                <!-- Header row with time and badge -->
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                                    <TextBlock Text="{Binding DisplayTime}" FontSize="12" FontWeight="Medium"
                                                               Foreground="{DynamicResource TextBrush}"/>
                                                    <Border Background="{DynamicResource SecondaryTextBrush}" 
                                                            CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                                                            Opacity="0.7" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DurationBadge}" FontSize="10"
                                                                   Foreground="{DynamicResource CardBrush}"/>
                                                    </Border>
                                                </StackPanel>
                                                
                                                <!-- Editable text area -->
                                                <TextBox x:Name="TextDisplay" 
                                                         Text="{Binding Text, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         TextWrapping="Wrap" 
                                                         AcceptsReturn="False"
                                                         Background="Transparent"
                                                         BorderThickness="0"
                                                         Foreground="{DynamicResource TextBrush}"
                                                         FontSize="14"
                                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibilityConverter}}"
                                                         LostFocus="TextBox_LostFocus"
                                                         KeyDown="TextBox_KeyDown"/>
                                                
                                                <!-- Truncated text display -->
                                                <StackPanel Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding DisplayText}" TextWrapping="Wrap" 
                                                               Foreground="{DynamicResource TextBrush}"
                                                               FontSize="14" MaxHeight="80"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Button x:Name="ShowMoreButton" 
                                                            Content="{Binding ExpandButtonText}"
                                                            Click="ShowMoreButton_Click"
                                                            Tag="{Binding Id}"
                                                            Style="{DynamicResource LinkButtonStyle}"
                                                            HorizontalAlignment="Left"
                                                            Margin="0,4,0,0"
                                                            Visibility="{Binding ShowExpandButton, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                                </StackPanel>
                                                
                                                <!-- Click to edit hint -->
                                                <TextBlock Text="Click text to edit" 
                                                           FontSize="10" 
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Margin="0,4,0,0"
                                                           Opacity="0.6"
                                                           Visibility="{Binding IsMouseOver, ElementName=CardBorder, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                            </StackPanel>
                                            
                                            <!-- Hover-reveal actions -->
                                            <StackPanel x:Name="ActionsPanel" Grid.Column="2" 
                                                        Orientation="Horizontal" VerticalAlignment="Top"
                                                        Opacity="0">
                                                <Button Content="Copy" Click="CopyTranscription_Click"
                                                        Tag="{Binding Id}"
                                                        Style="{DynamicResource SmallButtonStyle}" Margin="4,0"/>
                                                <Button Content="Delete" Click="DeleteTranscription_Click"
                                                        Tag="{Binding Id}"
                                                        Style="{DynamicResource SmallDangerButtonStyle}"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ActionsPanel" Property="Opacity" Value="1"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Empty State -->
                        <StackPanel x:Name="EmptyStatePanel" 
                                    VerticalAlignment="Center" HorizontalAlignment="Center"
                                    Visibility="Collapsed">
                            <TextBlock Text="🎙️" FontSize="64" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                            <TextBlock Text="No transcriptions yet" 
                                       FontSize="24" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="Press Ctrl+Shift+A to record" 
                                       FontSize="14"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Grid>

                    <!-- Bottom toolbar -->
                    <Grid Grid.Row="2" Margin="0,10,0,0">
                        <!-- Right side: Clear controls -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <ComboBox x:Name="ClearOlderThanComboBox" Width="140" Margin="0,0,8,0">
                                <ComboBoxItem Content="1 hour" Tag="1"/>
                                <ComboBoxItem Content="6 hours" Tag="6"/>
                                <ComboBoxItem Content="24 hours" Tag="24"/>
                                <ComboBoxItem Content="7 days" Tag="168" IsSelected="True"/>
                                <ComboBoxItem Content="30 days" Tag="720"/>
                                <ComboBoxItem Content="90 days" Tag="2160"/>
                            </ComboBox>
                            <Button x:Name="ClearOlderThanButton" Content="Clear Older Than"
                                    Click="ClearOlderThanButton_Click"
                                    Style="{DynamicResource SecondaryButtonStyle}" Margin="0,0,15,0"/>
                            <Rectangle Width="1" Fill="#555555" Margin="0,5,15,5"/>
                            <Button x:Name="ClearAllButton" Content="Clear All"
                                    Click="ClearAllButton_Click"
                                    Style="{DynamicResource SecondaryButtonStyle}"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- Transform Tab (Disabled) -->
            <TabItem Header="Transform" IsEnabled="False">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Text Transformation" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Transform transcribed text using AI"
                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,20"/>

                        <!-- Transformation Settings -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Transformation Settings" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                
                                <!-- Transformation Type -->
                                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                    <TextBlock Text="Type:" VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextBrush}" Width="100"/>
                                    <ComboBox x:Name="TransformationTypeComboBox" Width="200">
                                        <ComboBoxItem Content="Grammar" Tag="Grammar"/>
                                        <ComboBoxItem Content="Tone" Tag="Tone"/>
                                        <ComboBoxItem Content="Voice" Tag="Voice"/>
                                        <ComboBoxItem Content="Complexity" Tag="Complexity"/>
                                        <ComboBoxItem Content="Professionalism" Tag="Professionalism"/>
                                        <ComboBoxItem Content="Personal Style" Tag="PersonalStyle"/>
                                        <ComboBoxItem Content="Translation" Tag="Translation"/>
                                        <ComboBoxItem Content="Custom" Tag="Custom"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Direction -->
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Direction:" VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextBrush}" Width="100"/>
                                    <ComboBox x:Name="TransformationDirectionComboBox" Width="200">
                                        <ComboBoxItem Content="Default" Tag="Default"/>
                                        <ComboBoxItem Content="Formal" Tag="Formal"/>
                                        <ComboBoxItem Content="Informal" Tag="Informal"/>
                                        <ComboBoxItem Content="Active" Tag="Active"/>
                                        <ComboBoxItem Content="Passive" Tag="Passive"/>
                                        <ComboBoxItem Content="Simplify" Tag="Simplify"/>
                                        <ComboBoxItem Content="Elaborate" Tag="Elaborate"/>
                                        <ComboBoxItem Content="Professional" Tag="Professional"/>
                                        <ComboBoxItem Content="Casual" Tag="Casual"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Target Language (for Translation) -->
                                <StackPanel x:Name="TargetLanguagePanel" Orientation="Horizontal" Margin="0,10,0,0" Visibility="Collapsed">
                                    <TextBlock Text="Target Language:" VerticalAlignment="Center" 
                                               Foreground="{DynamicResource TextBrush}" Width="100"/>
                                    <ComboBox x:Name="TransformTargetLanguageComboBox" Width="200">
                                        <ComboBoxItem Content="English (en)" Tag="en" IsSelected="True"/>
                                        <ComboBoxItem Content="Spanish (es)" Tag="es"/>
                                        <ComboBoxItem Content="French (fr)" Tag="fr"/>
                                        <ComboBoxItem Content="German (de)" Tag="de"/>
                                        <ComboBoxItem Content="Italian (it)" Tag="it"/>
                                        <ComboBoxItem Content="Portuguese (pt)" Tag="pt"/>
                                        <ComboBoxItem Content="Russian (ru)" Tag="ru"/>
                                        <ComboBoxItem Content="Chinese (zh)" Tag="zh"/>
                                        <ComboBoxItem Content="Japanese (ja)" Tag="ja"/>
                                        <ComboBoxItem Content="Korean (ko)" Tag="ko"/>
                                        <ComboBoxItem Content="Arabic (ar)" Tag="ar"/>
                                        <ComboBoxItem Content="Hindi (hi)" Tag="hi"/>
                                    </ComboBox>
                                </StackPanel>

                                <!-- Preserve Options -->
                                <StackPanel Margin="0,15,0,0">
                                    <CheckBox x:Name="PreserveProperNounsCheckBox" Content="Preserve proper nouns (names, places)" 
                                              IsChecked="True"
                                              Foreground="{DynamicResource TextBrush}"/>
                                    <CheckBox x:Name="PreserveTechnicalTermsCheckBox" Content="Preserve technical terms" 
                                              IsChecked="True" Margin="0,5,0,0"
                                              Foreground="{DynamicResource TextBrush}"/>
                                </StackPanel>

                                <!-- Quality Threshold -->
                                <StackPanel Margin="0,15,0,0">
                                    <TextBlock Text="Quality Threshold" Foreground="{DynamicResource TextBrush}"/>
                                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                        <Slider x:Name="QualityThresholdSlider" Width="200" Minimum="0" Maximum="100" Value="70"
                                                TickFrequency="10" IsSnapToTickEnabled="True"/>
                                        <TextBlock x:Name="QualityThresholdValue" Text="70" Margin="10,0,0,0" 
                                                   VerticalAlignment="Center" Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Text Input -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Input Text" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Enter or paste text to transform"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"/>
                                <TextBox x:Name="TransformInputTextBox" 
                                         AcceptsReturn="True" 
                                         TextWrapping="Wrap"
                                         Height="120"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="5"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <Button x:Name="TransformButton" Content="Transform" 
                                            Click="TransformButton_Click"
                                            Style="{DynamicResource PrimaryButtonStyle}"
                                            Padding="20,8"/>
                                    <Button x:Name="ClearTransformButton" Content="Clear" 
                                            Click="ClearTransformButton_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Margin="10,0,0,0" Padding="20,8"/>
                                    <Button x:Name="PasteToTransformButton" Content="Paste from Clipboard" 
                                            Click="PasteToTransformButton_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Margin="10,0,0,0" Padding="20,8"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Transformation Output -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Transformed Text" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBox x:Name="TransformOutputTextBox" 
                                         AcceptsReturn="True" 
                                         TextWrapping="Wrap"
                                         Height="120"
                                         IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="5"
                                         Margin="0,10,0,0"/>
                                
                                <!-- Quality Metrics -->
                                <StackPanel x:Name="QualityMetricsPanel" Visibility="Collapsed" Margin="0,15,0,0">
                                    <TextBlock Text="Quality Metrics" FontSize="14" FontWeight="SemiBold"
                                               Foreground="{DynamicResource TextBrush}"/>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="Similarity:" Grid.Row="0" Grid.Column="0" 
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <ProgressBar x:Name="SimilarityProgressBar" Grid.Row="0" Grid.Column="1" 
                                                     Minimum="0" Maximum="100" Height="10" Margin="0,3"
                                                     Background="{DynamicResource CardBrush}"
                                                     Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock x:Name="SimilarityText" Grid.Row="0" Grid.Column="2" 
                                                   Foreground="{DynamicResource TextBrush}" TextAlignment="Right"/>

                                        <TextBlock Text="Confidence:" Grid.Row="1" Grid.Column="0" Margin="0,5,0,0"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <ProgressBar x:Name="ConfidenceProgressBar" Grid.Row="1" Grid.Column="1" 
                                                     Minimum="0" Maximum="100" Height="10" Margin="0,8,0,0"
                                                     Background="{DynamicResource CardBrush}"
                                                     Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock x:Name="ConfidenceText" Grid.Row="1" Grid.Column="2" Margin="0,5,0,0"
                                                   Foreground="{DynamicResource TextBrush}" TextAlignment="Right"/>

                                        <TextBlock Text="Readability:" Grid.Row="2" Grid.Column="0" Margin="0,5,0,0"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <ProgressBar x:Name="ReadabilityProgressBar" Grid.Row="2" Grid.Column="1" 
                                                     Minimum="0" Maximum="100" Height="10" Margin="0,8,0,0"
                                                     Background="{DynamicResource CardBrush}"
                                                     Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock x:Name="ReadabilityText" Grid.Row="2" Grid.Column="2" Margin="0,5,0,0"
                                                   Foreground="{DynamicResource TextBrush}" TextAlignment="Right"/>

                                        <TextBlock Text="Overall:" Grid.Row="3" Grid.Column="0" Margin="0,5,0,0"
                                                   Foreground="{DynamicResource TextBrush}" FontWeight="SemiBold"/>
                                        <ProgressBar x:Name="OverallProgressBar" Grid.Row="3" Grid.Column="1" 
                                                     Minimum="0" Maximum="100" Height="14" Margin="0,8,0,0"
                                                     Background="{DynamicResource CardBrush}"
                                                     Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock x:Name="OverallScoreText" Grid.Row="3" Grid.Column="2" Margin="0,5,0,0"
                                                   Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" TextAlignment="Right"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Output Actions -->
                                <StackPanel Orientation="Horizontal" Margin="0,15,0,0">
                                    <Button x:Name="CopyTransformedButton" Content="Copy" 
                                            Click="CopyTransformedButton_Click"
                                            Style="{DynamicResource SecondaryButtonStyle}"
                                            Padding="15,5"/>
                                    <Button x:Name="ApplyToOutputButton" Content="Apply to Output" 
                                            Click="ApplyToOutputButton_Click"
                                            Style="{DynamicResource PrimaryButtonStyle}"
                                            Margin="10,0,0,0" Padding="15,5"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Profiles Section -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Transformation Profiles" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Save and manage transformation settings as profiles"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"/>

                                <!-- Profile List -->
                                <ListBox x:Name="TransformationProfilesListBox" 
                                         Background="Transparent" BorderThickness="0"
                                         MaxHeight="150"
                                         SelectionChanged="TransformationProfilesListBox_SelectionChanged"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="{DynamicResource CardBrush}" CornerRadius="4" Padding="10" Margin="0,3">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel Grid.Column="0">
                                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource TextBrush}"/>
                                                        <TextBlock Text="{Binding Description}" FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                                    </StackPanel>
                                                    <Button Grid.Column="1" Content="Load" 
                                                            Click="LoadProfileButton_Click"
                                                            Tag="{Binding Id}"
                                                            Style="{DynamicResource SecondaryButtonStyle}" 
                                                            Padding="10,3" Margin="5,0"/>
                                                    <Button Grid.Column="2" Content="Delete" 
                                                            Click="DeleteProfileButton_Click"
                                                            Tag="{Binding Id}"
                                                            Style="{DynamicResource SecondaryButtonStyle}" 
                                                            Padding="10,3"/>
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>

                                <!-- Create New Profile -->
                                <StackPanel Margin="0,15,0,0">
                                    <TextBlock Text="Create New Profile" Foreground="{DynamicResource TextBrush}"/>
                                    <Grid Margin="0,10,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="NewProfileNameBox" Grid.Column="0" 
                                                 VerticalContentAlignment="Center" Padding="5" Margin="0,0,5,0"
                                                 ToolTipService.ToolTip="Profile name"/>
                                        <TextBox x:Name="NewProfileDescriptionBox" Grid.Column="1" 
                                                 VerticalContentAlignment="Center" Padding="5" Margin="5,0,5,0"
                                                 ToolTipService.ToolTip="Profile description"/>
                                        <Button x:Name="CreateProfileButton" Grid.Column="2" Content="Create" 
                                                Click="CreateProfileButton_Click"
                                                Style="{DynamicResource PrimaryButtonStyle}" Padding="15,5"/>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Status -->
                        <TextBlock x:Name="TransformStatusText" Margin="0,20,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
