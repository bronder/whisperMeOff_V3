<Window x:Class="whisperMeOff.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="whisperMeOff"
        Height="800" Width="800"
        MinHeight="400" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource HeaderBrush}" Padding="20,15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Status Indicator -->
                    <Ellipse Width="12" Height="12" Fill="{DynamicResource AccentBrush}" x:Name="StatusIndicator"/>
                    <TextBlock Text="Ready" FontSize="16" FontWeight="SemiBold" Margin="10,0,0,0"
                               Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Ctrl+Shift+" Foreground="{DynamicResource TextBrush}" VerticalAlignment="Center"/>
                    <TextBlock Text="R" x:Name="HotkeyDisplay" Foreground="{DynamicResource AccentBrush}"
                               FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <Button Content="Settings" Click="OpenSettings_Click"
                            Style="{DynamicResource SecondaryButtonStyle}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Content -->
        <TabControl Grid.Row="1" x:Name="MainTabControl" Background="Transparent" BorderThickness="0">
            <!-- Home Tab -->
            <TabItem Header="Home">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <!-- Welcome Section -->
                        <TextBlock Text="whisperMeOff" FontSize="28" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>
                        <TextBlock Text="Offline voice-to-text transcription with auto-paste"
                                   FontSize="14" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,20"/>

                        <!-- Quick Start -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20">
                            <StackPanel>
                                <TextBlock Text="Quick Start" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,0,0">
                                    <Run Text="1. Hold"/>
                                    <Run Text=" Ctrl+Shift+" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/><Run x:Name="QuickStartHotkeyRun" Text="R" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                                    <Run Text=" to stop recording and transcribe"/>
                                </TextBlock>
                                <TextBlock Text="2. Speak your text" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0">
                                    <Run Text="3. Release to transcribe - text automatically appears in your target app"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Last Transcription -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Last Transcription" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock x:Name="LastTranscriptionText" Text="No transcriptions yet"
                                           TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,10,0,0" MaxHeight="100"/>
                            </StackPanel>
                        </Border>

                        <!-- Recording Button (Fallback) -->
                        <Button Content="Start Recording" x:Name="RecordButton" Click="RecordButton_Click"
                                Style="{DynamicResource PrimaryButtonStyle}" Margin="0,20,0,0"
                                HorizontalAlignment="Left" Padding="30,10"/>

                        <!-- Audio Level Meter -->
                        <ProgressBar x:Name="AudioLevelMeter" Height="8" Margin="0,10,0,0"
                                     Minimum="0" Maximum="1" Value="0"
                                     Visibility="Collapsed"
                                     Background="{DynamicResource CardBrush}"
                                     Foreground="{DynamicResource AccentBrush}"/>

                        <!-- Model Status -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Status" FontSize="16" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <Grid Margin="0,10,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Whisper:" Grid.Row="0" Grid.Column="0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="Not loaded" x:Name="WhisperStatusText" Grid.Row="0" Grid.Column="1"
                                               Foreground="{DynamicResource TextBrush}"/>

                                    <TextBlock Text="Llama:" Grid.Row="1" Grid.Column="0" Margin="0,5,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="Disabled" x:Name="LlamaStatusText" Grid.Row="1" Grid.Column="1" Margin="0,5,0,0"
                                               Foreground="{DynamicResource TextBrush}"/>

                                    <TextBlock Text="Hotkey:" Grid.Row="2" Grid.Column="0" Margin="0,5,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="Ctrl+Shift+R" x:Name="HotkeyStatusText" Grid.Row="2" Grid.Column="1" Margin="0,5,0,0"
                                               Foreground="{DynamicResource TextBrush}"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="General Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Hotkey Configuration -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Push-to-Talk Hotkey" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Ctrl+Shift+" Foreground="{DynamicResource TextBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBox x:Name="HotkeyTriggerTextBox" Width="40" MaxLength="1"
                                             TextAlignment="Center" TextChanged="HotkeyTriggerTextBox_TextChanged"
                                             VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBlock Text="Type a single letter or number. The Ctrl+Shift modifiers are fixed."
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Whisper Model Download Path -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Whisper Model Download Path" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Custom folder for Whisper models (.bin files)"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="ModelDownloadPathTextBox" Grid.Column="0" 
                                             VerticalContentAlignment="Center" Padding="5"
                                             TextChanged="ModelDownloadPathTextBox_TextChanged"/>
                                    <Button x:Name="BrowseDownloadPathBtn" Content="Browse..." Grid.Column="1" 
                                            Click="BrowseDownloadPath_Click" Margin="10,0,0,0"
                                            Style="{DynamicResource SecondaryButtonStyle}"/>
                                </Grid>
                                <TextBlock x:Name="DownloadPathStatusText" Margin="0,10,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Llama Model Download Path -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Llama Model Download Path" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Custom folder for GGUF models (.gguf files)"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox x:Name="LlamaDownloadPathTextBox" Grid.Column="0" 
                                             VerticalContentAlignment="Center" Padding="5"
                                             TextChanged="LlamaDownloadPathTextBox_TextChanged"/>
                                    <Button x:Name="BrowseLlamaDownloadPathBtn" Content="Browse..." Grid.Column="1" 
                                            Click="BrowseLlamaDownloadPath_Click" Margin="10,0,0,0"
                                            Style="{DynamicResource SecondaryButtonStyle}"/>
                                </Grid>
                                <TextBlock x:Name="LlamaDownloadPathStatusText" Margin="0,10,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}"/>
                            </StackPanel>
                        </Border>

                        <!-- Launch at Login -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <CheckBox x:Name="LaunchAtLoginCheckbox" Content="Launch at login"
                                          Checked="LaunchAtLoginCheckbox_Changed" Unchecked="LaunchAtLoginCheckbox_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Clipboard Restore -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Clipboard Settings" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <CheckBox x:Name="RestoreClipboardCheckbox" Content="Restore previous clipboard after paste"
                                          Margin="0,10,0,0"
                                          Checked="RestoreClipboardCheckbox_Changed" Unchecked="RestoreClipboardCheckbox_Changed"/>
                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="Restore delay (ms):" Foreground="{DynamicResource TextBrush}" 
                                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <TextBox x:Name="ClipboardDelayTextBox" Width="80" TextAlignment="Center"
                                             TextChanged="ClipboardDelayTextBox_TextChanged"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Recording Mode -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Recording Mode" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <CheckBox x:Name="PushToTalkCheckbox" Content="Push-to-talk (hold hotkey to record)"
                                          Margin="0,10,0,0"
                                          Checked="PushToTalkCheckbox_Changed" Unchecked="PushToTalkCheckbox_Changed"/>
                                <TextBlock Text="When off: Press hotkey to start/stop recording (toggle mode)"
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Audio Tab -->
            <TabItem Header="Audio">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Audio Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Microphone Selection -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Microphone" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <ComboBox x:Name="MicrophoneComboBox" Margin="0,10,0,0"
                                          SelectionChanged="MicrophoneComboBox_SelectionChanged"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Whisper Tab -->
            <TabItem Header="Whisper">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Whisper Settings" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Language -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Language" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <ComboBox x:Name="LanguageComboBox" Margin="0,10,0,0"
                                          SelectionChanged="LanguageComboBox_SelectionChanged">
                                    <ComboBoxItem Content="Auto Detect" Tag="auto"/>
                                    <ComboBoxItem Content="English" Tag="en"/>
                                    <ComboBoxItem Content="Spanish" Tag="es"/>
                                    <ComboBoxItem Content="French" Tag="fr"/>
                                    <ComboBoxItem Content="German" Tag="de"/>
                                    <ComboBoxItem Content="Italian" Tag="it"/>
                                    <ComboBoxItem Content="Portuguese" Tag="pt"/>
                                    <ComboBoxItem Content="Russian" Tag="ru"/>
                                    <ComboBoxItem Content="Chinese" Tag="zh"/>
                                    <ComboBoxItem Content="Japanese" Tag="ja"/>
                                    <ComboBoxItem Content="Korean" Tag="ko"/>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- Translate -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <CheckBox x:Name="TranslateCheckbox" Content="Translate to English"
                                          Checked="TranslateCheckbox_Changed" Unchecked="TranslateCheckbox_Changed"/>
                            </StackPanel>
                        </Border>

                        <!-- Model Selection -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Model" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock x:Name="ModelPathText" Text="No model selected"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,0,0"/>
                                <Button Content="Select Model File..." Click="SelectModel_Click"
                                        Style="{DynamicResource SecondaryButtonStyle}" Margin="0,10,0,0"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Download Models -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Download Models" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock Text="Download different Whisper model sizes"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,10"/>

                                <StackPanel x:Name="DownloadModelsPanel">
                                    <!-- Tiny -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Tiny" Grid.Column="0" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="~75MB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Button x:Name="DownloadTinyBtn" Content="Download" Grid.Column="3" Click="DownloadTiny_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}"/>
                                    </Grid>
                                    <!-- Base -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Base" Grid.Column="0" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="~150MB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Button x:Name="DownloadBaseBtn" Content="Download" Grid.Column="3" Click="DownloadBase_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}"/>
                                    </Grid>
                                    <!-- Small -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Small" Grid.Column="0" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="~500MB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Button x:Name="DownloadSmallBtn" Content="Download" Grid.Column="3" Click="DownloadSmall_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}"/>
                                    </Grid>
                                    <!-- Medium -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Medium" Grid.Column="0" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="~1.5GB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Button x:Name="DownloadMediumBtn" Content="Download" Grid.Column="3" Click="DownloadMedium_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}"/>
                                    </Grid>
                                    <!-- Large -->
                                    <Grid Margin="0,5">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Large" Grid.Column="0" Foreground="{DynamicResource TextBrush}"/>
                                        <TextBlock Text="~3GB" Grid.Column="1" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                        <Button x:Name="DownloadLargeBtn" Content="Download" Grid.Column="3" Click="DownloadLarge_Click"
                                                Style="{DynamicResource SecondaryButtonStyle}"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Download Progress -->
                                <ProgressBar x:Name="DownloadProgressBar" Height="8" Margin="0,15,0,0"
                                             Visibility="Collapsed" Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock x:Name="DownloadStatusText" Margin="0,5,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Visibility="Collapsed"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Llama Tab -->
            <TabItem Header="Llama">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <TextBlock Text="Llama Text Formatting" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource TextBrush}"/>

                        <!-- Enable Llama -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <CheckBox x:Name="LlamaEnableCheckbox" Content="Enable Llama text formatting"
                                          Checked="LlamaEnableCheckbox_Changed" Unchecked="LlamaEnableCheckbox_Changed"/>
                                <TextBlock Text="Automatically format transcribed text with Llama"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Model Selection -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Model" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBlock x:Name="LlamaModelPathText" Text="No model selected"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,10,0,0"/>
                                <Button Content="Select Model File..." Click="SelectLlamaModel_Click"
                                        Style="{DynamicResource SecondaryButtonStyle}" Margin="0,10,0,0"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- Download from HuggingFace -->
                        <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="20" Margin="0,20,0,0">
                            <StackPanel>
                                <TextBlock Text="Download from HuggingFace" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}"/>
                                <TextBox x:Name="HuggingFaceModelIdTextBox" Margin="0,10,0,0"
                                         TextChanged="HuggingFaceModelIdTextBox_TextChanged"/>
                                <TextBlock Text="Find models at huggingface.co/models — search for GGUF quantized models"
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,5,0,0"
                                           TextWrapping="Wrap"/>
                                <Button Content="Download Model" Click="DownloadLlamaModel_Click"
                                        Style="{DynamicResource PrimaryButtonStyle}" Margin="0,10,0,0"
                                        HorizontalAlignment="Left"/>

                                <!-- Download Progress for Llama -->
                                <ProgressBar x:Name="LlamaDownloadProgressBar" Height="8" Margin="0,15,0,0"
                                             Visibility="Collapsed" Background="{DynamicResource CardBrush}"
                                             Foreground="{DynamicResource AccentBrush}"/>
                                <TextBlock x:Name="LlamaDownloadStatusText" Margin="0,5,0,0"
                                           Foreground="{DynamicResource SecondaryTextBrush}" Visibility="Collapsed"/>

                                <!-- HuggingFace Token -->
                                <TextBlock Text="HuggingFace Token (for private models)" FontSize="14" FontWeight="SemiBold"
                                           Foreground="{DynamicResource TextBrush}" Margin="0,20,0,0"/>
                                <PasswordBox x:Name="HuggingFaceTokenBox" Margin="0,10,0,0"
                                             PasswordChanged="HuggingFaceTokenBox_PasswordChanged"/>
                                <TextBlock Text="Required for gated/private models. Get yours at huggingface.co/settings/tokens"
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- History Tab -->
            <TabItem Header="History">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Search -->
                            <TextBox x:Name="SearchTextBox" Grid.Row="0"
                                     TextChanged="SearchTextBox_TextChanged"/>

                    <!-- History List -->
                    <ListBox x:Name="HistoryListBox" Grid.Row="1" Margin="0,10,0,0"
                             Background="Transparent" BorderThickness="0">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBrush}" CornerRadius="8" Padding="15" Margin="0,5">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding DisplayTime}" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"/>
                                            <TextBlock Text="{Binding Text}" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource TextBrush}" MaxHeight="60"/>
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal">
                                            <Button Content="Copy" Click="CopyTranscription_Click"
                                                    Tag="{Binding Id}"
                                                    Style="{DynamicResource SecondaryButtonStyle}" Margin="5,0"/>
                                            <Button Content="Delete" Click="DeleteTranscription_Click"
                                                    Tag="{Binding Id}"
                                                    Style="{DynamicResource SecondaryButtonStyle}"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Clear All -->
                    <Button x:Name="ClearAllButton" Grid.Row="2" Content="Clear All"
                            Click="ClearAllButton_Click"
                            Style="{DynamicResource SecondaryButtonStyle}" Margin="0,10,0,0"
                            HorizontalAlignment="Right"/>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
