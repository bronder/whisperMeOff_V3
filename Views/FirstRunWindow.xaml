<Window x:Class="whisperMeOff.Views.FirstRunWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome to whisperMeOff"
        Width="500" Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        WindowStyle="SingleBorderWindow">
    
    <Window.Resources>
        <!-- Toggle Switch Style -->
        <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid>
                            <Border x:Name="Background" Width="44" Height="22" CornerRadius="11" 
                                    Background="#CCCCCC" BorderBrush="#999999" BorderThickness="1"/>
                            <Ellipse x:Name="Thumb" Width="18" Height="18" Fill="White" 
                                     HorizontalAlignment="Left" Margin="2,0,0,0">
                                <Ellipse.Effect>
                                    <DropShadowEffect ShadowDepth="1" BlurRadius="2" Opacity="0.3"/>
                                </Ellipse.Effect>
                            </Ellipse>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Background" Property="Background" Value="#0078D4"/>
                                <Setter TargetName="Background" Property="BorderBrush" Value="#005A9E"/>
                                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/>
                                <Setter TargetName="Thumb" Property="Margin" Value="0,0,2,0"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Feature Icon Style -->
        <Style x:Key="FeatureIconStyle" TargetType="Border">
            <Setter Property="Width" Value="50"/>
            <Setter Property="Height" Value="50"/>
            <Setter Property="CornerRadius" Value="25"/>
            <Setter Property="Background" Value="#0078D4"/>
        </Style>
        
        <!-- Glowing Button Style -->
        <Style x:Key="GlowButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="40,15"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}"
                                CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <Border.Effect>
                                <DropShadowEffect ShadowDepth="0" BlurRadius="20" Color="#0078D4" Opacity="0.5"/>
                            </Border.Effect>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E8AD4"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#005A9E"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    
    <Grid Background="#F5F5F5">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Hero Section -->
        <Border Grid.Row="0" Background="White" Padding="30,40">
            <StackPanel HorizontalAlignment="Center">
                <!-- Robot Icon -->
                <Border Width="80" Height="80" CornerRadius="40" Background="#0078D4" Margin="0,0,0,20">
                    <Image Source="pack://application:,,,/flatrobot_white.ico" Width="60" Height="60"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Border>
                
                <TextBlock Text="whisperMeOff" 
                           FontSize="32" FontWeight="Bold" 
                           HorizontalAlignment="Center"
                           Foreground="#1E1E1E"/>
                <TextBlock Text="Your offline voice transcription assistant"
                           FontSize="14" 
                           HorizontalAlignment="Center"
                           Foreground="#666666" 
                           Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
        
        <!-- Content - Single Column Flow -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="30,20">
            <StackPanel>
                <!-- Feature Icons Row -->
                <Grid Margin="0,0,0,30">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Feature 1: Mic -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <Border Style="{StaticResource FeatureIconStyle}">
                            <TextBlock Text="🎙️" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <TextBlock Text="Instant Record" FontSize="12" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="Black"/>
                    </StackPanel>
                    
                    <!-- Feature 2: Paste -->
                    <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                        <Border Style="{StaticResource FeatureIconStyle}">
                            <TextBlock Text="📋" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <TextBlock Text="Paste Anywhere" FontSize="12" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="Black"/>
                    </StackPanel>
                    
                    <!-- Feature 3: AI -->
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                        <Border Style="{StaticResource FeatureIconStyle}">
                            <TextBlock Text="🤖" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <TextBlock Text="AI Grammar" FontSize="12" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="Black"/>
                    </StackPanel>
                    
                    <!-- Feature 4: Lock -->
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                        <Border Style="{StaticResource FeatureIconStyle}">
                            <TextBlock Text="🔒" FontSize="24" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <TextBlock Text="100% Offline" FontSize="12" FontWeight="SemiBold" 
                                   HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="Black"/>
                    </StackPanel>
                </Grid>
                
                <!-- Hotkey Selector -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🎹 Your Hotkey" FontSize="16" FontWeight="Bold" Foreground="#1E1E1E" Margin="0,0,0,15"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Ctrl + Shift + " FontSize="16" FontWeight="SemiBold" 
                                       VerticalAlignment="Center" Foreground="#333333"/>
                            <TextBox x:Name="HotkeyTextBox" Width="45" Height="40" FontSize="20" FontWeight="Bold"
                                     TextAlignment="Center" VerticalContentAlignment="Center"
                                     MaxLength="1" CharacterCasing="Upper" Padding="2,0"
                                     Text="R" TextChanged="HotkeyTextBox_TextChanged"/>
                        </StackPanel>
                        <TextBlock x:Name="CurrentHotkeyText" Text="Press Ctrl+Shift+R to record"
                                   FontSize="12" Foreground="#666666" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Theme Selector -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="🎨 Theme" FontSize="16" FontWeight="Bold" Foreground="#1E1E1E" Margin="0,0,0,15"/>
                        <ComboBox x:Name="ThemeComboBox" FontSize="14" Padding="10,8"
                                  SelectionChanged="ThemeComboBox_SelectionChanged">
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="14" Fill="#FFFFFF" Stroke="#CCCCCC" Margin="0,0,8,0"/>
                                    <TextBlock Text="Light"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="14" Fill="#1E1E1E" Stroke="#444444" Margin="0,0,8,0"/>
                                    <TextBlock Text="Dark"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="14" Fill="#2E3440" Stroke="#4C566A" Margin="0,0,8,0"/>
                                    <TextBlock Text="Nord"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="14" Fill="#282A36" Stroke="#BD93F9" Margin="0,0,8,0"/>
                                    <TextBlock Text="Dracula"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="14" Fill="#282828" Stroke="#B8BB26" Margin="0,0,8,0"/>
                                    <TextBlock Text="Gruvbox"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="14" Fill="#272822" Stroke="#F92672" Margin="0,0,8,0"/>
                                    <TextBlock Text="Monokai"/>
                                </StackPanel>
                            </ComboBoxItem>
                            <ComboBoxItem>
                                <StackPanel Orientation="Horizontal">
                                    <Rectangle Width="20" Height="14" Fill="#1A142A" Stroke="#FF6BC8" Margin="0,0,8,0"/>
                                    <TextBlock Text="Synthwave"/>
                                </StackPanel>
                            </ComboBoxItem>
                        </ComboBox>
                        <TextBlock x:Name="ThemePreviewText" Text="Select your preferred theme"
                                   FontSize="12" Foreground="#666666" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
                
                <!-- Optional Settings -->
                <Border Background="White" CornerRadius="12" Padding="20" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="⚙️ Optional Settings" FontSize="16" FontWeight="Bold" Foreground="#1E1E1E" Margin="0,0,0,15"/>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Launch at startup" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" x:Name="LaunchAtLoginCheckBox" Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>
                        <Grid Margin="0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Minimize to tray" VerticalAlignment="Center"/>
                            <ToggleButton Grid.Column="1" x:Name="MinimizeToTrayCheckBox" Style="{StaticResource ToggleSwitchStyle}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        
        <!-- Footer with Button -->
        <Border Grid.Row="2" Background="White" Padding="30,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="SkipButton" Content="Skip" 
                        Background="Transparent" Foreground="#888888"
                        BorderThickness="0" Padding="10,12"
                        FontSize="14"
                        Cursor="Hand"
                        VerticalAlignment="Center"
                        Click="SkipButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="border" Background="{TemplateBinding Background}"
                                    CornerRadius="4" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="border" Property="Background" Value="#E0E0E0"/>
                                    <Setter Property="Foreground" Value="#333333"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Button Grid.Column="2" x:Name="GetStartedButton" Content="Get Started →" 
                        Style="{StaticResource GlowButtonStyle}"
                        Margin="30,0,0,0"
                        Click="GetStartedButton_Click"/>
            </Grid>
        </Border>
    </Grid>
</Window>
